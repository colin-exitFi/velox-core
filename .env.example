# =============================================================================
# Velox Core — minimum viable config. Copy to .env and fill in.
# =============================================================================

# === Alpaca (paper account; data + execution) ===
ALPACA_API_KEY=<your-paper-key>
ALPACA_SECRET_KEY=<your-paper-secret>
ALPACA_PAPER=true

# === AI providers — Claude + GPT consensus, no Grok in v1 ===
ANTHROPIC_API_KEY=<your-anthropic-key>
OPENAI_API_KEY=<your-openai-key>
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
OPENAI_MODEL=gpt-5.4-mini

# === Trading parameters ===
POSITION_SIZE_PCT=4.0
MAX_CONCURRENT_POSITIONS=8
MIN_CONSENSUS_CONFIDENCE=60
PAPER_STARTING_EQUITY=25000

# === Profit ratchet (proven values from velox-classic data) ===
RATCHET_HARD_STOP_PCT=-0.75
RATCHET_ACTIVATION_PCT=0.30
RATCHET_TRAIL_PCT=1.00
RATCHET_INITIAL_FLOOR_PCT=0.10
RATCHET_MIN_HOLD_SECONDS=120

# === Dashboard ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8422
DASHBOARD_TOKEN=<set-a-token>

# === Kill switch (set to true to halt all new entries; existing positions still managed) ===
TRADING_HALTED=false

# === Logging ===
LOG_LEVEL=INFO
